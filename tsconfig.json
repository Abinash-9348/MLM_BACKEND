{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "isolatedModules": true,
    "resolveJsonModule": true,

    "noEmit": false
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules", "generated", "prisma.config.ts"]
}
